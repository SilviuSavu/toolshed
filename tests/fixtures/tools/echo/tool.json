{
  "name": "echo",
  "description": "Echo test tool",
  "category": "testing",
  "type": "native",
  "commands": {
    "say": {
      "description": "Echo back the input",
      "args": {
        "message": {
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Message to echo"
        }
      }
    },
    "greet": {
      "description": "Greet someone",
      "args": {
        "name": {
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Name to greet"
        },
        "--loud": {
          "type": "bool",
          "required": false,
          "positional": false,
          "default": false,
          "description": "Shout the greeting"
        }
      }
    }
  }
}
