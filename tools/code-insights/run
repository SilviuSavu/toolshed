#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# code-insights: Track Sourcegraph search result counts over time
# ---------------------------------------------------------------------------

VAULT_ADDR="${VAULT_ADDR:-http://127.0.0.1:8200}"
VAULT_TOKEN="${VAULT_TOKEN:-toolshed-dev-token}"
DB_DIR="$HOME/.toolshed/data"
DB_PATH="$DB_DIR/code-insights.db"

# ── Helpers ────────────────────────────────────────────────────────────────

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo ":: $*"; }

ensure_db() {
  mkdir -p "$DB_DIR"
  sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS insights (
    name TEXT PRIMARY KEY,
    query TEXT NOT NULL,
    description TEXT,
    interval_hours INTEGER DEFAULT 24,
    created_at TEXT DEFAULT (datetime('now'))
);
CREATE TABLE IF NOT EXISTS data_points (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    insight_name TEXT NOT NULL,
    match_count INTEGER NOT NULL,
    by_repo TEXT,
    collected_at TEXT DEFAULT (datetime('now')),
    FOREIGN KEY (insight_name) REFERENCES insights(name)
);
SQL
}

load_credentials() {
  local secret
  secret=$(curl -sf -H "X-Vault-Token: $VAULT_TOKEN" \
    "$VAULT_ADDR/v1/secret/data/sourcegraph") \
    || die "Failed to fetch Sourcegraph credentials from Vault"

  SG_URL=$(echo "$secret" | jq -r '.data.data.url')
  SG_TOKEN=$(echo "$secret" | jq -r '.data.data.token')

  [[ -n "$SG_URL" && "$SG_URL" != "null" ]]     || die "Sourcegraph URL not found in Vault"
  [[ -n "$SG_TOKEN" && "$SG_TOKEN" != "null" ]]  || die "Sourcegraph token not found in Vault"
}

# Run a Sourcegraph GraphQL search and return the raw JSON response.
sg_search() {
  local query="$1"
  local gql_query='query Search($q: String!) {
    search(query: $q) {
      results {
        matchCount
        results {
          ... on FileMatch {
            repository { name }
            file { path }
            lineMatches { lineNumber preview }
          }
        }
      }
    }
  }'

  local payload
  payload=$(jq -n --arg q "$query" --arg gql "$gql_query" \
    '{ query: $gql, variables: { q: $q } }')

  curl -sf -X POST \
    -H "Authorization: token $SG_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$payload" \
    "${SG_URL}/.api/graphql" \
    || die "Sourcegraph GraphQL request failed"
}

# Extract match count from a search response.
extract_match_count() {
  jq -r '.data.search.results.matchCount // 0' <<< "$1"
}

# Build a JSON object of { repo_name: count } from the search response.
extract_by_repo() {
  jq -c '
    [.data.search.results.results // [] | .[] |
      select(.repository != null) |
      .repository.name as $repo |
      { repo: $repo, matches: (.lineMatches | length) }
    ] |
    group_by(.repo) |
    map({ (.[0].repo): (map(.matches) | add) }) |
    add // {}
  ' <<< "$1"
}

# Collect data for one insight by name.
collect_one() {
  local name="$1"
  local query
  query=$(sqlite3 "$DB_PATH" "SELECT query FROM insights WHERE name='$name';")
  [[ -n "$query" ]] || die "Insight '$name' not found"

  info "Collecting: $name  (query: $query)"

  local response
  response=$(sg_search "$query")

  local count
  count=$(extract_match_count "$response")

  local by_repo
  by_repo=$(extract_by_repo "$response")

  sqlite3 "$DB_PATH" "INSERT INTO data_points (insight_name, match_count, by_repo) VALUES ('$name', $count, '$(echo "$by_repo" | sed "s/'/''/g")');"

  info "  Recorded: count=$count  repos=$(echo "$by_repo" | jq 'length')"
}

# ── Bar rendering ──────────────────────────────────────────────────────────

render_bar() {
  local value="$1" max_value="$2" max_width="${3:-40}"
  local blocks="▏▎▍▌▋▊▉█"

  if [[ "$max_value" -eq 0 ]]; then
    echo ""
    return
  fi

  # Compute width in eighths
  local eighths=$(( value * max_width * 8 / max_value ))
  local full=$(( eighths / 8 ))
  local remainder=$(( eighths % 8 ))

  local bar=""
  for (( i=0; i<full; i++ )); do
    bar+="█"
  done
  if [[ "$remainder" -gt 0 ]]; then
    # Extract the fractional block character (UTF-8 aware)
    local idx=$(( remainder - 1 ))
    local frac
    frac=$(echo "$blocks" | grep -oP '.'{1} | sed -n "$(( idx + 1 ))p" 2>/dev/null || true)
    # Fallback: use bash substring on the known characters
    if [[ -z "$frac" ]]; then
      local block_chars=(▏ ▎ ▍ ▌ ▋ ▊ ▉ █)
      frac="${block_chars[$idx]}"
    fi
    bar+="$frac"
  fi

  echo "$bar"
}

# ── Commands ───────────────────────────────────────────────────────────────

cmd_create() {
  local name="" query="" description="" interval=24

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)        name="$2"; shift 2 ;;
      --query)       query="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --interval)    interval="$2"; shift 2 ;;
      *) die "Unknown argument: $1" ;;
    esac
  done

  [[ -n "$name" ]]  || die "--name is required"
  [[ -n "$query" ]] || die "--query is required"

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT name FROM insights WHERE name='$name';")
  [[ -z "$existing" ]] || die "Insight '$name' already exists"

  sqlite3 "$DB_PATH" "INSERT INTO insights (name, query, description, interval_hours) VALUES ('$(echo "$name" | sed "s/'/''/g")', '$(echo "$query" | sed "s/'/''/g")', '$(echo "$description" | sed "s/'/''/g")', $interval);"

  info "Created insight: $name"
  info "  Query:    $query"
  info "  Interval: ${interval}h"
  [[ -z "$description" ]] || info "  Desc:     $description"
}

cmd_collect() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *) die "Unknown argument: $1" ;;
    esac
  done

  ensure_db
  load_credentials

  if [[ -n "$name" ]]; then
    collect_one "$name"
  else
    local names
    names=$(sqlite3 "$DB_PATH" "SELECT name FROM insights ORDER BY name;")
    [[ -n "$names" ]] || die "No insights defined"
    while IFS= read -r n; do
      collect_one "$n"
    done <<< "$names"
  fi

  info "Collection complete."
}

cmd_collect_all() {
  ensure_db
  load_credentials

  local names
  names=$(sqlite3 "$DB_PATH" "SELECT name FROM insights ORDER BY name;")
  [[ -n "$names" ]] || die "No insights defined"

  while IFS= read -r n; do
    collect_one "$n"
  done <<< "$names"

  info "All collections complete."
}

cmd_trend() {
  local name="" days=30 fmt="text"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days)   days="$2"; shift 2 ;;
      --format) fmt="$2"; shift 2 ;;
      -*)       die "Unknown flag: $1" ;;
      *)        [[ -z "$name" ]] && name="$1" || die "Unexpected argument: $1"; shift ;;
    esac
  done

  [[ -n "$name" ]] || die "Insight name is required (positional)"

  ensure_db

  local query_text
  query_text=$(sqlite3 "$DB_PATH" "SELECT query FROM insights WHERE name='$name';")
  [[ -n "$query_text" ]] || die "Insight '$name' not found"

  local rows
  rows=$(sqlite3 -separator '|' "$DB_PATH" \
    "SELECT date(collected_at) as d, match_count
     FROM data_points
     WHERE insight_name='$name'
       AND collected_at >= datetime('now', '-${days} days')
     ORDER BY collected_at ASC;")

  if [[ -z "$rows" ]]; then
    info "No data points for '$name' in the last ${days} days."
    return
  fi

  if [[ "$fmt" == "json" ]]; then
    local json_arr="[]"
    local prev_count=""
    while IFS='|' read -r date count; do
      local delta="null"
      if [[ -n "$prev_count" ]]; then
        delta=$(( count - prev_count ))
      fi
      json_arr=$(echo "$json_arr" | jq --arg d "$date" --argjson c "$count" --argjson dl "$delta" \
        '. + [{ date: $d, count: $c, delta: $dl }]')
      prev_count="$count"
    done <<< "$rows"

    jq -n --arg name "$name" --arg query "$query_text" --argjson days "$days" --argjson points "$json_arr" \
      '{ insight: $name, query: $query, days: $days, data: $points }'
    return
  fi

  # Text format with ASCII bars
  echo ""
  echo "$name (last $days days)"
  echo "Query: $query_text"
  echo ""

  # Find max count for scaling
  local max_count=0
  while IFS='|' read -r _ count; do
    (( count > max_count )) && max_count=$count
  done <<< "$rows"

  printf "%-12s %6s %6s  %s\n" "Date" "Count" "Delta" ""
  printf "%-12s %6s %6s  %s\n" "----" "-----" "-----" ""

  local prev_count=""
  while IFS='|' read -r date count; do
    local delta_str=""
    if [[ -n "$prev_count" ]]; then
      local d=$(( count - prev_count ))
      if (( d > 0 )); then
        delta_str="+${d}"
      elif (( d < 0 )); then
        delta_str="${d}"
      else
        delta_str="0"
      fi
    fi

    local bar
    bar=$(render_bar "$count" "$max_count" 40)

    printf "%-12s %6d %6s  %s\n" "$date" "$count" "$delta_str" "$bar"
    prev_count="$count"
  done <<< "$rows"

  echo ""
}

cmd_compare() {
  local name1="" name2="" days=30

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days) days="$2"; shift 2 ;;
      -*)     die "Unknown flag: $1" ;;
      *)
        if [[ -z "$name1" ]]; then
          name1="$1"
        elif [[ -z "$name2" ]]; then
          name2="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$name1" ]] || die "First insight name is required (positional)"
  [[ -n "$name2" ]] || die "Second insight name is required (positional)"

  ensure_db

  local q1 q2
  q1=$(sqlite3 "$DB_PATH" "SELECT query FROM insights WHERE name='$name1';")
  q2=$(sqlite3 "$DB_PATH" "SELECT query FROM insights WHERE name='$name2';")
  [[ -n "$q1" ]] || die "Insight '$name1' not found"
  [[ -n "$q2" ]] || die "Insight '$name2' not found"

  echo ""
  echo "Comparing: $name1 vs $name2 (last $days days)"
  echo "  $name1 query: $q1"
  echo "  $name2 query: $q2"
  echo ""

  # Collect all dates from both insights
  local all_dates
  all_dates=$(sqlite3 "$DB_PATH" \
    "SELECT DISTINCT date(collected_at) as d
     FROM data_points
     WHERE insight_name IN ('$name1','$name2')
       AND collected_at >= datetime('now', '-${days} days')
     ORDER BY d ASC;")

  if [[ -z "$all_dates" ]]; then
    info "No data points for either insight in the last ${days} days."
    return
  fi

  printf "%-12s %12s %12s\n" "Date" "$name1" "$name2"
  printf "%-12s %12s %12s\n" "----" "$(printf '%0.s-' $(seq 1 ${#name1}))" "$(printf '%0.s-' $(seq 1 ${#name2}))"

  while IFS= read -r date; do
    local c1 c2
    c1=$(sqlite3 "$DB_PATH" \
      "SELECT match_count FROM data_points
       WHERE insight_name='$name1' AND date(collected_at)='$date'
       ORDER BY collected_at DESC LIMIT 1;")
    c2=$(sqlite3 "$DB_PATH" \
      "SELECT match_count FROM data_points
       WHERE insight_name='$name2' AND date(collected_at)='$date'
       ORDER BY collected_at DESC LIMIT 1;")

    printf "%-12s %12s %12s\n" "$date" "${c1:--}" "${c2:--}"
  done <<< "$all_dates"

  echo ""
}

cmd_snapshot() {
  ensure_db
  load_credentials

  local names
  names=$(sqlite3 "$DB_PATH" "SELECT name FROM insights ORDER BY name;")
  [[ -n "$names" ]] || die "No insights defined"

  echo ""
  printf "%-30s %8s  %s\n" "Insight" "Count" "Query"
  printf "%-30s %8s  %s\n" "-------" "-----" "-----"

  while IFS= read -r name; do
    local query
    query=$(sqlite3 "$DB_PATH" "SELECT query FROM insights WHERE name='$name';")

    local response
    response=$(sg_search "$query")

    local count
    count=$(extract_match_count "$response")

    printf "%-30s %8d  %s\n" "$name" "$count" "$query"
  done <<< "$names"

  echo ""
  info "Snapshot complete (results not stored)."
}

cmd_list() {
  ensure_db

  local rows
  rows=$(sqlite3 -separator '|' "$DB_PATH" \
    "SELECT i.name, i.description, i.query, i.interval_hours,
            COUNT(d.id) as data_points,
            MAX(d.collected_at) as last_collected
     FROM insights i
     LEFT JOIN data_points d ON d.insight_name = i.name
     GROUP BY i.name
     ORDER BY i.name;")

  if [[ -z "$rows" ]]; then
    info "No insights defined. Use 'create' to add one."
    return
  fi

  echo ""
  printf "%-25s %-35s %6s %12s  %s\n" "Name" "Query" "Points" "Last Collected" "Description"
  printf "%-25s %-35s %6s %12s  %s\n" "----" "-----" "------" "--------------" "-----------"

  while IFS='|' read -r name desc query interval points last; do
    printf "%-25s %-35s %6s %12s  %s\n" \
      "$name" \
      "$(echo "$query" | cut -c1-33)" \
      "${points:-0}" \
      "${last:--}" \
      "${desc:--}"
  done <<< "$rows"

  echo ""
}

cmd_delete() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*) die "Unknown flag: $1" ;;
      *)  [[ -z "$name" ]] && name="$1" || die "Unexpected argument: $1"; shift ;;
    esac
  done

  [[ -n "$name" ]] || die "Insight name is required (positional)"

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT name FROM insights WHERE name='$name';")
  [[ -n "$existing" ]] || die "Insight '$name' not found"

  local point_count
  point_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM data_points WHERE insight_name='$name';")

  sqlite3 "$DB_PATH" "DELETE FROM data_points WHERE insight_name='$name'; DELETE FROM insights WHERE name='$name';"

  info "Deleted insight '$name' and $point_count data point(s)."
}

cmd_health() {
  local ok=true

  # Check database
  ensure_db
  if sqlite3 "$DB_PATH" "SELECT 1;" &>/dev/null; then
    local insight_count
    insight_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM insights;")
    local point_count
    point_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM data_points;")
    info "Database: OK ($insight_count insights, $point_count data points)"
  else
    echo "ERROR: Database not accessible at $DB_PATH"
    ok=false
  fi

  # Check Vault + Sourcegraph credentials
  if load_credentials 2>/dev/null; then
    info "Vault: OK (credentials loaded)"
  else
    echo "ERROR: Cannot load credentials from Vault at $VAULT_ADDR"
    ok=false
  fi

  # Check Sourcegraph connectivity
  if [[ "${SG_URL:-}" != "" ]]; then
    local status
    status=$(curl -sf -o /dev/null -w '%{http_code}' \
      -H "Authorization: token $SG_TOKEN" \
      "${SG_URL}/.api/graphql" \
      -X POST -d '{"query":"{ currentUser { username } }"}' 2>/dev/null || echo "000")
    if [[ "$status" == "200" ]]; then
      info "Sourcegraph: OK ($SG_URL)"
    else
      echo "ERROR: Sourcegraph returned HTTP $status at $SG_URL"
      ok=false
    fi
  fi

  if $ok; then
    info "All checks passed."
  else
    exit 1
  fi
}

# ── Dispatch ───────────────────────────────────────────────────────────────

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  create)      cmd_create "$@" ;;
  collect)     cmd_collect "$@" ;;
  collect-all) cmd_collect_all "$@" ;;
  trend)       cmd_trend "$@" ;;
  compare)     cmd_compare "$@" ;;
  snapshot)    cmd_snapshot "$@" ;;
  list)        cmd_list "$@" ;;
  delete)      cmd_delete "$@" ;;
  health)      cmd_health "$@" ;;
  *)           die "Unknown command: $COMMAND (expected: create|collect|collect-all|trend|compare|snapshot|list|delete|health)" ;;
esac
