{
  "name": "code-insights",
  "description": "Track Sourcegraph search result counts over time to visualize code trends and compare metrics",
  "category": "monitoring",
  "type": "native",
  "max_output": 25000,
  "health": "code-insights health",
  "commands": {
    "create": {
      "description": "Create a new insight (tracked metric)",
      "args": {
        "--name": {
          "required": true,
          "description": "Insight name (e.g. \"deprecated-api-usage\")",
          "type": "string",
          "positional": false
        },
        "--query": {
          "required": true,
          "description": "Sourcegraph search query (e.g. \"lang:go fmt.Println\")",
          "type": "string",
          "positional": false
        },
        "--description": {
          "required": false,
          "description": "Human-readable description of the insight",
          "type": "string",
          "positional": false
        },
        "--interval": {
          "required": false,
          "description": "Collection interval in hours (default: 24, informational — actual scheduling is external)",
          "type": "string",
          "positional": false
        }
      }
    },
    "collect": {
      "description": "Run a collection for a specific insight or all insights",
      "args": {
        "--name": {
          "required": false,
          "description": "Specific insight to collect (if omitted, collects all)",
          "type": "string",
          "positional": false
        }
      }
    },
    "collect-all": {
      "description": "Collect data for all insights",
      "args": {}
    },
    "trend": {
      "description": "Show the trend for an insight with ASCII sparkline chart",
      "args": {
        "name": {
          "positional": true,
          "required": true,
          "description": "Name of the insight",
          "type": "string"
        },
        "--days": {
          "required": false,
          "description": "Number of days to show (default: 30)",
          "type": "string",
          "positional": false
        },
        "--format": {
          "required": false,
          "description": "Output format: text or json (default: text)",
          "type": "string",
          "positional": false
        }
      }
    },
    "compare": {
      "description": "Compare two insights side by side",
      "args": {
        "name1": {
          "positional": true,
          "required": true,
          "description": "First insight name",
          "type": "string"
        },
        "name2": {
          "positional": true,
          "required": true,
          "description": "Second insight name",
          "type": "string"
        },
        "--days": {
          "required": false,
          "description": "Number of days to show (default: 30)",
          "type": "string",
          "positional": false
        }
      }
    },
    "snapshot": {
      "description": "Get current values for all insights without storing results",
      "args": {}
    },
    "list": {
      "description": "List all insights with their status",
      "args": {}
    },
    "delete": {
      "description": "Delete an insight and all its collected data",
      "args": {
        "name": {
          "positional": true,
          "required": true,
          "description": "Name of the insight to delete",
          "type": "string"
        }
      }
    },
    "health": {
      "description": "Check Sourcegraph connectivity and database state",
      "args": {}
    }
  }
}
