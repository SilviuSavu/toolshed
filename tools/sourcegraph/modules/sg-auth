#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# sg-auth — Sourcegraph authentication & user management (ADMIN)
###############################################################################

VAULT_ADDR="${VAULT_ADDR:-http://127.0.0.1:8200}"
VAULT_TOKEN="${VAULT_TOKEN:-toolshed-dev-token}"

_vault_data=$(curl -sf -H "X-Vault-Token: $VAULT_TOKEN" "$VAULT_ADDR/v1/secret/data/sourcegraph")
SG_URL=$(echo "$_vault_data" | jq -r '.data.data.url')
SG_TOKEN=$(echo "$_vault_data" | jq -r '.data.data.token')
unset _vault_data

graphql() {
    curl -sf -H "Authorization: token $SG_TOKEN" \
        -H 'Content-Type: application/json' \
        -X POST "$SG_URL/.api/graphql" \
        -d "$1"
}

die() { echo "ERROR: $*" >&2; exit 1; }

check_admin() {
    local result
    result=$(graphql '{"query":"{ currentUser { siteAdmin } }"}')
    local is_admin
    is_admin=$(echo "$result" | jq -r '.data.currentUser.siteAdmin // false')
    [[ "$is_admin" != "true" ]] && die "this command requires site admin privileges"
}

###############################################################################
# COMMANDS
###############################################################################

cmd_list_auth_providers() {
    local gql_payload='{"query":"{ site { authProviders { nodes { serviceType serviceID clientID displayName isBuiltin authenticationURL } totalCount } } }"}'

    local result
    result=$(graphql "$gql_payload")

    local total
    total=$(echo "$result" | jq -r '.data.site.authProviders.totalCount // 0')
    echo "Authentication providers ($total configured):"
    echo "---"
    echo "$result" | jq -r '
        .data.site.authProviders.nodes[]? |
        "\(.serviceType)\(if .displayName then " — \(.displayName)" else "" end)",
        "  Service ID: \(.serviceID // "N/A")",
        "  Client ID: \(.clientID // "N/A")",
        "  Builtin: \(.isBuiltin)",
        ""
    '
}

cmd_get_auth_provider() {
    local serviceType=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*)  die "unknown flag: $1" ;;
            *)   serviceType="$1"; shift ;;
        esac
    done

    [[ -z "$serviceType" ]] && die "serviceType is required"

    local gql_payload='{"query":"{ site { authProviders { nodes { serviceType serviceID clientID displayName isBuiltin authenticationURL } } } }"}'

    local result
    result=$(graphql "$gql_payload")

    echo "$result" | jq -r --arg st "$serviceType" '
        .data.site.authProviders.nodes[]? |
        select(.serviceType == $st) |
        "Service Type: \(.serviceType)",
        "Service ID: \(.serviceID // "N/A")",
        "Client ID: \(.clientID // "N/A")",
        "Display Name: \(.displayName // "N/A")",
        "Builtin: \(.isBuiltin)",
        "Auth URL: \(.authenticationURL // "N/A")"
    '
}

cmd_list_users() {
    local query="" first="25" after=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --query) query="$2"; shift 2 ;;
            --first) first="$2"; shift 2 ;;
            --after) after="$2"; shift 2 ;;
            -*)      die "unknown flag: $1" ;;
            *)       die "unexpected argument: $1" ;;
        esac
    done

    local gql_payload
    gql_payload=$(jq -n \
        --arg query "$query" \
        --argjson first "$first" \
        --arg after "$after" \
        '{
            query: "query ListUsers($query: String, $first: Int!, $after: String) { users(query: $query, first: $first, after: $after) { nodes { id username displayName emails { email verified } siteAdmin createdAt updatedAt } totalCount pageInfo { hasNextPage endCursor } } }",
            variables: {
                query: (if $query != "" then $query else null end),
                first: $first,
                after: (if $after != "" then $after else null end)
            }
        }')

    local result
    result=$(graphql "$gql_payload")

    local total
    total=$(echo "$result" | jq -r '.data.users.totalCount // 0')
    echo "Users (showing up to $first of $total):"
    echo "---"
    echo "$result" | jq -r '
        .data.users.nodes[]? |
        "\(.username)\(if .siteAdmin then " [ADMIN]" else "" end)",
        "  Display: \(.displayName // "N/A")",
        "  Email: \(.emails[0].email // "N/A")\(if .emails[0].verified then " (verified)" else " (unverified)" end)",
        "  ID: \(.id)",
        "  Created: \(.createdAt)",
        ""
    '
}

cmd_get_user() {
    local username=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*)  die "unknown flag: $1" ;;
            *)   username="$1"; shift ;;
        esac
    done

    [[ -z "$username" ]] && die "username is required"

    local gql_payload
    gql_payload=$(jq -n \
        --arg username "$username" \
        '{
            query: "query GetUser($username: String!) { user(username: $username) { id username displayName emails { email verified } siteAdmin createdAt updatedAt organizations { nodes { name } } roles { nodes { name } } } }",
            variables: { username: $username }
        }')

    local result
    result=$(graphql "$gql_payload")

    local uname
    uname=$(echo "$result" | jq -r '.data.user.username // empty')
    if [[ -z "$uname" ]]; then
        die "user not found: $username"
    fi

    echo "$result" | jq -r '
        .data.user |
        "Username: \(.username)",
        "Display Name: \(.displayName // "N/A")",
        "ID: \(.id)",
        "Site Admin: \(.siteAdmin)",
        "Created: \(.createdAt)",
        "Updated: \(.updatedAt)",
        "Emails:",
        (.emails[]? | "  \(.email)\(if .verified then " (verified)" else " (unverified)" end)"),
        "Organizations:",
        (.organizations.nodes[]? | "  \(.name)"),
        "Roles:",
        (.roles.nodes[]? | "  \(.name)")
    '
}

cmd_create_user() {
    local username="" email=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --username) username="$2"; shift 2 ;;
            --email)    email="$2";    shift 2 ;;
            -*)         die "unknown flag: $1" ;;
            *)          die "unexpected argument: $1" ;;
        esac
    done

    [[ -z "$username" ]] && die "--username is required"
    [[ -z "$email" ]]    && die "--email is required"

    check_admin

    local gql_payload
    gql_payload=$(jq -n \
        --arg username "$username" \
        --arg email "$email" \
        '{
            query: "mutation CreateUser($username: String!, $email: String!) { createUser(username: $username, email: $email) { user { id username } resetPasswordURL } }",
            variables: { username: $username, email: $email }
        }')

    local result
    result=$(graphql "$gql_payload")

    local new_id
    new_id=$(echo "$result" | jq -r '.data.createUser.user.id // empty')
    if [[ -z "$new_id" ]]; then
        local errors
        errors=$(echo "$result" | jq -r '.errors[]?.message // empty' 2>/dev/null)
        die "failed to create user: ${errors:-unknown error}"
    fi

    local reset_url
    reset_url=$(echo "$result" | jq -r '.data.createUser.resetPasswordURL // "N/A"')

    echo "Created user: $username"
    echo "ID: $new_id"
    echo "Password reset URL: $reset_url"
}

cmd_delete_user() {
    local username="" hard="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --hard) hard="$2"; shift 2 ;;
            -*)     die "unknown flag: $1" ;;
            *)      username="$1"; shift ;;
        esac
    done

    [[ -z "$username" ]] && die "username is required"

    check_admin

    # Resolve username to ID
    local user_result
    user_result=$(graphql "$(jq -n --arg u "$username" '{query: "query { user(username: \"'$username'\") { id } }"}')")
    local user_id
    user_id=$(echo "$user_result" | jq -r '.data.user.id // empty')
    [[ -z "$user_id" ]] && die "user not found: $username"

    local hard_bool="false"
    [[ "$hard" == "true" ]] && hard_bool="true"

    local gql_payload
    gql_payload=$(jq -n \
        --arg id "$user_id" \
        --argjson hard "$hard_bool" \
        '{
            query: "mutation DeleteUser($id: ID!, $hard: Boolean!) { deleteUser(user: $id, hard: $hard) { alwaysNil } }",
            variables: { id: $id, hard: $hard }
        }')

    local result
    result=$(graphql "$gql_payload")

    local errors
    errors=$(echo "$result" | jq -r '.errors[]?.message // empty' 2>/dev/null)
    if [[ -n "$errors" ]]; then
        die "failed to delete user: $errors"
    fi

    echo "Deleted user: $username (hard: $hard)"
}

cmd_set_site_admin() {
    local username="" admin=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --admin) admin="$2"; shift 2 ;;
            -*)      die "unknown flag: $1" ;;
            *)       username="$1"; shift ;;
        esac
    done

    [[ -z "$username" ]] && die "username is required"
    [[ -z "$admin" ]]    && die "--admin is required (true or false)"

    check_admin

    # Resolve username to ID
    local user_result
    user_result=$(graphql "$(jq -n --arg u "$username" '{query: "query { user(username: \"'$username'\") { id } }"}')")
    local user_id
    user_id=$(echo "$user_result" | jq -r '.data.user.id // empty')
    [[ -z "$user_id" ]] && die "user not found: $username"

    local admin_bool="false"
    [[ "$admin" == "true" ]] && admin_bool="true"

    local gql_payload
    gql_payload=$(jq -n \
        --arg id "$user_id" \
        --argjson admin "$admin_bool" \
        '{
            query: "mutation SetUserSiteAdmin($id: ID!, $admin: Boolean!) { setUserIsSiteAdmin(userID: $id, siteAdmin: $admin) { alwaysNil } }",
            variables: { id: $id, admin: $admin }
        }')

    local result
    result=$(graphql "$gql_payload")

    local errors
    errors=$(echo "$result" | jq -r '.errors[]?.message // empty' 2>/dev/null)
    if [[ -n "$errors" ]]; then
        die "failed to set admin status: $errors"
    fi

    if [[ "$admin_bool" == "true" ]]; then
        echo "Promoted $username to site admin"
    else
        echo "Demoted $username from site admin"
    fi
}

cmd_get_site_config_auth() {
    check_admin

    local gql_payload='{"query":"{ site { configuration { effectiveContents } } }"}'

    local result
    result=$(graphql "$gql_payload")

    local config
    config=$(echo "$result" | jq -r '.data.site.configuration.effectiveContents // empty')
    if [[ -z "$config" ]]; then
        die "could not read site configuration"
    fi

    # Extract only auth-related fields
    echo "Authentication configuration:"
    echo "---"
    echo "$config" | jq '
        {
            "auth.providers": .["auth.providers"],
            "auth.public": .["auth.public"],
            "auth.accessTokens": .["auth.accessTokens"],
            "auth.sessionExpiry": .["auth.sessionExpiry"],
            "auth.minPasswordLength": .["auth.minPasswordLength"]
        } | to_entries | map(select(.value != null)) | from_entries
    ' 2>/dev/null || echo "$config"
}

cmd_update_site_config_auth() {
    local config=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config) config="$2"; shift 2 ;;
            -*)       die "unknown flag: $1" ;;
            *)        die "unexpected argument: $1" ;;
        esac
    done

    [[ -z "$config" ]] && die "--config is required (JSON object)"

    check_admin

    # Validate JSON
    echo "$config" | jq empty 2>/dev/null || die "--config must be valid JSON"

    # Read current config, merge auth changes, write back
    local current_result
    current_result=$(graphql '{"query":"{ site { configuration { id effectiveContents } } }"}')
    local config_id
    config_id=$(echo "$current_result" | jq -r '.data.site.configuration.id // empty')
    local current_config
    current_config=$(echo "$current_result" | jq -r '.data.site.configuration.effectiveContents // "{}"')

    local merged
    merged=$(echo "$current_config" | jq --argjson updates "$config" '. * $updates')

    local gql_payload
    gql_payload=$(jq -n \
        --argjson lastID "$config_id" \
        --arg input "$merged" \
        '{
            query: "mutation UpdateSiteConfig($lastID: Int!, $input: String!) { updateSiteConfiguration(lastID: $lastID, input: $input) { alwaysNil } }",
            variables: { lastID: $lastID, input: $input }
        }')

    local result
    result=$(graphql "$gql_payload")

    local errors
    errors=$(echo "$result" | jq -r '.errors[]?.message // empty' 2>/dev/null)
    if [[ -n "$errors" ]]; then
        die "failed to update site config: $errors"
    fi

    echo "Site authentication configuration updated."
    echo "WARNING: Changes take effect immediately."
}

cmd_health() {
    local ok=true

    echo "Checking Sourcegraph auth management access ..."

    if [[ -z "$SG_URL" || "$SG_URL" == "null" ]]; then
        echo "  FAILED: could not load Sourcegraph URL from Vault"
        ok=false
    elif [[ -z "$SG_TOKEN" || "$SG_TOKEN" == "null" ]]; then
        echo "  FAILED: could not load Sourcegraph token from Vault"
        ok=false
    else
        local result
        result=$(graphql '{"query":"{ currentUser { username siteAdmin } }"}')
        local username
        username=$(echo "$result" | jq -r '.data.currentUser.username // empty')
        local is_admin
        is_admin=$(echo "$result" | jq -r '.data.currentUser.siteAdmin // false')

        if [[ -n "$username" ]]; then
            echo "  Auth: OK (user: $username, admin: $is_admin)"
        else
            echo "  Auth: FAILED (could not authenticate)"
            ok=false
        fi
    fi

    if [[ "$ok" == "true" ]]; then
        echo "All services healthy."
    else
        echo "Some services are unhealthy." >&2
        return 1
    fi
}

###############################################################################
# Dispatch
###############################################################################

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    list_auth_providers)   cmd_list_auth_providers "$@" ;;
    get_auth_provider)     cmd_get_auth_provider "$@" ;;
    list_users)            cmd_list_users "$@" ;;
    get_user)              cmd_get_user "$@" ;;
    create_user)           cmd_create_user "$@" ;;
    delete_user)           cmd_delete_user "$@" ;;
    set_site_admin)        cmd_set_site_admin "$@" ;;
    get_site_config_auth)  cmd_get_site_config_auth "$@" ;;
    update_site_config_auth) cmd_update_site_config_auth "$@" ;;
    health)                cmd_health "$@" ;;
    *)
        echo "Usage: sg-auth <command> [args]"
        echo ""
        echo "Commands:"
        echo "  list_auth_providers     List authentication providers"
        echo "  get_auth_provider       Get auth provider details"
        echo "  list_users              List users"
        echo "  get_user                Get user details"
        echo "  create_user             Create a user (admin)"
        echo "  delete_user             Delete a user (admin)"
        echo "  set_site_admin          Promote/demote admin (admin)"
        echo "  get_site_config_auth    Read auth config (admin)"
        echo "  update_site_config_auth Update auth config (admin)"
        echo "  health                  Check connectivity"
        exit 1
        ;;
esac
