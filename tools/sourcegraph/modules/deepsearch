#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# deepsearch — multi-step LLM-driven code research via native function calling
#
# Uses GLM-5's native tool_calls API (OpenAI-compatible) instead of parsing
# JSON from content. The model decides which tools to call, we execute them
# and return results via role:tool messages.
#
# Providers: zai (default, GLM-5), openrouter (Qwen3-coder)
###############################################################################

DB_DIR="$HOME/.toolshed/data"
DB_PATH="$DB_DIR/deepsearch.db"
TOOLSHED_URL="${TOOLSHED_URL:-http://127.0.0.1:8081}"
VAULT_ADDR="${VAULT_ADDR:-http://127.0.0.1:8200}"
VAULT_TOKEN="${VAULT_TOKEN:-toolshed-dev-token}"
MAX_STEPS=10
MAX_TOOL_OUTPUT=4000
PROVIDER="${DEEPSEARCH_PROVIDER:-zai}"

die() { echo "ERROR: $*" >&2; exit 1; }

LLM_API_KEY=""
LLM_BASE_URL=""
LLM_MODEL=""

load_provider() {
    local provider="$1"
    local vault_path="" default_model="" default_url=""

    case "$provider" in
        openrouter)
            default_model="qwen/qwen3-coder"
            vault_path="openrouter"
            default_url="https://openrouter.ai/api/v1/chat/completions"
            ;;
        zai)
            default_model="glm-5"
            vault_path="zai"
            default_url="https://api.z.ai/api/coding/paas/v4/chat/completions"
            ;;
        *)
            die "unknown provider: $provider (available: openrouter, zai)"
            ;;
    esac

    LLM_MODEL="${DEEPSEARCH_MODEL:-$default_model}"
    LLM_BASE_URL="$default_url"

    local vault_data
    vault_data=$(curl -sf -H "X-Vault-Token: $VAULT_TOKEN" \
        "$VAULT_ADDR/v1/secret/data/$vault_path") \
        || die "cannot reach Vault for provider $provider"

    LLM_API_KEY=$(echo "$vault_data" | jq -r '.data.data.api_key')
    [[ -n "$LLM_API_KEY" && "$LLM_API_KEY" != "null" ]] \
        || die "API key not found in Vault at secret/data/$vault_path"

    local vault_url
    vault_url=$(echo "$vault_data" | jq -r '.data.data.base_url // empty')
    if [[ -n "$vault_url" ]]; then
        LLM_BASE_URL="${vault_url}/chat/completions"
    fi
}

# ---------------------------------------------------------------------------
# Tool definitions for native function calling
# ---------------------------------------------------------------------------
TOOLS_JSON='[
  {"type":"function","function":{"name":"sourcegraph__keyword_search","description":"Search code across ALL remote repositories on Sourcegraph","parameters":{"type":"object","properties":{"query":{"type":"string","description":"Search query"},"count":{"type":"string","description":"Max results (default 30)"}},"required":["query"]}}},
  {"type":"function","function":{"name":"narsil__hybrid_search","description":"Semantic + keyword search on locally indexed repositories","parameters":{"type":"object","properties":{"query":{"type":"string","description":"Search query"},"repo":{"type":"string","description":"Limit to specific repo"},"limit":{"type":"integer","description":"Max results (default 10)"}},"required":["query"]}}},
  {"type":"function","function":{"name":"sourcegraph__symbols","description":"Find code symbols (functions, classes, types) across repositories","parameters":{"type":"object","properties":{"query":{"type":"string","description":"Symbol name to search"},"repo":{"type":"string","description":"Limit to specific repo"},"kind":{"type":"string","description":"Symbol kind filter"}},"required":["query"]}}},
  {"type":"function","function":{"name":"sourcegraph__read_file","description":"Read file content from a repository","parameters":{"type":"object","properties":{"repo":{"type":"string","description":"Repository name"},"path":{"type":"string","description":"File path"},"rev":{"type":"string","description":"Revision (default HEAD)"}},"required":["repo","path"]}}},
  {"type":"function","function":{"name":"narsil__go_to_definition","description":"Find definition of a symbol (AST-based)","parameters":{"type":"object","properties":{"repo":{"type":"string","description":"Repository name"},"file":{"type":"string","description":"File path"},"symbol":{"type":"string","description":"Symbol name"}},"required":["repo","file","symbol"]}}},
  {"type":"function","function":{"name":"narsil__find_references","description":"Find all references to a symbol (AST-based)","parameters":{"type":"object","properties":{"repo":{"type":"string","description":"Repository name"},"symbol":{"type":"string","description":"Symbol name"}},"required":["repo","symbol"]}}},
  {"type":"function","function":{"name":"narsil__call_graph","description":"Get outgoing function calls from a function","parameters":{"type":"object","properties":{"repo":{"type":"string","description":"Repository name"},"file":{"type":"string","description":"File path"},"function":{"type":"string","description":"Function name"}},"required":["repo","file","function"]}}},
  {"type":"function","function":{"name":"narsil__callers","description":"Find all callers of a function","parameters":{"type":"object","properties":{"repo":{"type":"string","description":"Repository name"},"file":{"type":"string","description":"File path"},"function":{"type":"string","description":"Function name"}},"required":["repo","file","function"]}}},
  {"type":"function","function":{"name":"lsp__find_definition","description":"Find definition of a symbol (compiler-accurate via LSP)","parameters":{"type":"object","properties":{"file_path":{"type":"string","description":"Full file path"},"symbol_name":{"type":"string","description":"Symbol name"}},"required":["file_path","symbol_name"]}}},
  {"type":"function","function":{"name":"lsp__find_references","description":"Find all references to a symbol (compiler-accurate via LSP)","parameters":{"type":"object","properties":{"file_path":{"type":"string","description":"Full file path"},"symbol_name":{"type":"string","description":"Symbol name"}},"required":["file_path","symbol_name"]}}}
]'

SYSTEM_PROMPT='You are a code research assistant. Investigate questions about codebases by using the provided tools.

Strategy:
- Search broadly first (keyword_search, hybrid_search)
- Read specific files to understand implementation details
- Trace definitions and references for deeper understanding
- Use call graphs to understand control flow

When you have enough information, respond with your final answer in markdown.
Do not call tools unnecessarily — be strategic and efficient.'

# ---------------------------------------------------------------------------
# LLM call — returns raw response JSON
# ---------------------------------------------------------------------------
llm_call() {
    local messages_json="$1"
    local payload
    payload=$(jq -n \
        --arg model "$LLM_MODEL" \
        --argjson messages "$messages_json" \
        --argjson tools "$TOOLS_JSON" \
        '{
            model: $model,
            messages: $messages,
            tools: $tools,
            tool_choice: "auto",
            max_tokens: 131072,
            thinking: {type: "enabled", clear_thinking: false}
        }')

    local http_response http_code body
    http_response=$(curl -s --max-time 300 -w '\n%{http_code}' \
        -H "Authorization: Bearer $LLM_API_KEY" \
        -H "Content-Type: application/json" \
        -d "$payload" \
        "$LLM_BASE_URL")
    http_code=$(echo "$http_response" | tail -1)
    body=$(echo "$http_response" | sed '$d')

    if [[ "$http_code" != "200" ]]; then
        local err_msg
        err_msg=$(echo "$body" | jq -r '.error.message // .message // "unknown error"' 2>/dev/null)
        die "LLM API failed ($PROVIDER: $LLM_MODEL) HTTP $http_code: $err_msg"
    fi

    echo "$body"
}

# ---------------------------------------------------------------------------
# Toolshed call
# ---------------------------------------------------------------------------
ts_call() {
    local tool_name="$1"
    local args_json="$2"
    local response
    response=$(curl -sf --max-time 60 \
        -X POST "$TOOLSHED_URL" \
        -H 'Content-Type: application/json' \
        -d "$(jq -n \
            --arg name "$tool_name" \
            --argjson args "$args_json" \
            '{jsonrpc:"2.0",id:1,method:"tools/call",params:{name:$name,arguments:$args}}'
        )") || { echo "[tool call failed: $tool_name]"; return 0; }

    local is_error
    is_error=$(echo "$response" | jq -r '.result.isError // false')
    if [[ "$is_error" == "true" ]]; then
        echo "[error: $(echo "$response" | jq -r '.result.content[0].text // "unknown"')]"
        return 0
    fi

    local text
    text=$(echo "$response" | jq -r '.result.content[0].text // empty')
    if [[ ${#text} -gt $MAX_TOOL_OUTPUT ]]; then
        echo "${text:0:$MAX_TOOL_OUTPUT}... [truncated]"
    else
        echo "$text"
    fi
}

# ---------------------------------------------------------------------------
# SQLite
# ---------------------------------------------------------------------------
ensure_db() {
    mkdir -p "$DB_DIR"
    sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS conversations (
    id TEXT PRIMARY KEY,
    question TEXT NOT NULL,
    answer TEXT,
    messages TEXT,
    provider TEXT,
    model TEXT,
    status TEXT DEFAULT 'running',
    steps INTEGER DEFAULT 0,
    created_at TEXT DEFAULT (datetime('now')),
    completed_at TEXT
);
SQL
}

generate_id() {
    printf '%s-%s' "$(date +%s)" "$(head -c4 /dev/urandom | xxd -p)"
}

# ---------------------------------------------------------------------------
# Main agent loop
# ---------------------------------------------------------------------------
cmd_deepsearch() {
    local question="" provider="$PROVIDER"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --question) question="$2";  shift 2 ;;
            --provider) provider="$2";  shift 2 ;;
            --model)    DEEPSEARCH_MODEL="$2"; shift 2 ;;
            -*)         die "unknown flag: $1" ;;
            *)          question="$1";  shift ;;
        esac
    done

    [[ -z "$question" ]] && die "question is required"
    PROVIDER="$provider"
    load_provider "$provider"
    ensure_db

    local conv_id
    conv_id=$(generate_id)

    local q_escaped
    q_escaped=$(echo "$question" | sed "s/'/''/g")
    sqlite3 "$DB_PATH" "INSERT INTO conversations (id, question, provider, model) VALUES ('$conv_id', '$q_escaped', '$provider', '$LLM_MODEL');"

    local messages
    messages=$(jq -n \
        --arg system "$SYSTEM_PROMPT" \
        --arg question "$question" \
        '[
            {"role": "system", "content": $system},
            {"role": "user", "content": $question}
        ]')

    local step=0
    local answer=""
    local final_status="completed"

    while [[ $step -lt $MAX_STEPS ]]; do
        step=$((step + 1))

        local raw_response
        raw_response=$(llm_call "$messages")

        local finish_reason
        finish_reason=$(echo "$raw_response" | jq -r '.choices[0].finish_reason // "stop"')

        local message
        message=$(echo "$raw_response" | jq -c '.choices[0].message')

        # Append assistant message to history (preserves tool_calls structure)
        messages=$(echo "$messages" | jq --argjson msg "$message" '. + [$msg]')

        if [[ "$finish_reason" == "tool_calls" ]]; then
            # Model wants to call tools — execute each and append tool results
            local num_calls
            num_calls=$(echo "$message" | jq '.tool_calls | length')

            for ((i = 0; i < num_calls; i++)); do
                local call_id tool_name arguments
                call_id=$(echo "$message" | jq -r ".tool_calls[$i].id")
                tool_name=$(echo "$message" | jq -r ".tool_calls[$i].function.name")
                arguments=$(echo "$message" | jq -r ".tool_calls[$i].function.arguments")

                # arguments comes as string from the API, parse it
                local args_obj
                args_obj=$(echo "$arguments" | jq -c '.' 2>/dev/null) || args_obj="$arguments"

                local result
                result=$(ts_call "$tool_name" "$args_obj")

                # Append tool result message
                messages=$(echo "$messages" | jq \
                    --arg role "tool" \
                    --arg content "$result" \
                    --arg tool_call_id "$call_id" \
                    '. + [{role: $role, content: $content, tool_call_id: $tool_call_id}]')
            done
        else
            # Model responded with content — this is the final answer
            answer=$(echo "$message" | jq -r '.content // empty')
            break
        fi
    done

    # If we hit MAX_STEPS without a final answer, force one
    if [[ -z "$answer" && $step -ge $MAX_STEPS ]]; then
        messages=$(echo "$messages" | jq \
            '. + [{"role": "user", "content": "Synthesize your final answer now based on all research so far."}]')

        # Call without tools to force a text response
        local final_payload
        final_payload=$(jq -n \
            --arg model "$LLM_MODEL" \
            --argjson messages "$messages" \
            '{model: $model, messages: $messages, max_tokens: 131072, thinking: {type: "enabled", clear_thinking: false}}')

        local final_resp
        final_resp=$(curl -s --max-time 300 \
            -H "Authorization: Bearer $LLM_API_KEY" \
            -H "Content-Type: application/json" \
            -d "$final_payload" \
            "$LLM_BASE_URL")

        answer=$(echo "$final_resp" | jq -r '.choices[0].message.content // empty')
        [[ -z "$answer" ]] && answer="Failed to synthesize answer after $MAX_STEPS steps"
    fi

    # Store in SQLite
    local tmpdir
    tmpdir=$(mktemp -d)
    echo "$answer" > "$tmpdir/answer"
    echo "$messages" > "$tmpdir/messages"
    sqlite3 "$DB_PATH" "UPDATE conversations SET answer = readfile('$tmpdir/answer'), messages = readfile('$tmpdir/messages'), status = '$final_status', steps = $step, completed_at = datetime('now') WHERE id = '$conv_id';"
    rm -rf "$tmpdir"

    echo "# Deep Search Result"
    echo ""
    echo "**ID:** $conv_id"
    echo "**Provider:** $provider ($LLM_MODEL)"
    echo "**Steps:** $step"
    echo "**Status:** $final_status"
    echo ""
    echo "---"
    echo ""
    echo "$answer"
}

cmd_deepsearch "$@"
