#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# code-monitor — watch for new commits via Sourcegraph and send alerts
# Aligned with Sourcegraph Enterprise Code Monitoring GraphQL API naming
# ---------------------------------------------------------------------------

DB_DIR="$HOME/.toolshed/data"
DB_PATH="$DB_DIR/code-monitor.db"

TOOLSHED_URL="${TOOLSHED_URL:-http://localhost:8081}"

# ---- helpers --------------------------------------------------------------

ts_call() {
  local tool="$1"
  shift
  local args_json="$@"
  local response
  response=$(curl -sf --max-time 30 -X POST "$TOOLSHED_URL" \
    -H "Content-Type: application/json" \
    -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"$tool\",\"arguments\":$args_json}}")
  local is_err
  is_err=$(echo "$response" | jq -r '.result.isError // false')
  if [[ "$is_err" == "true" ]]; then
    echo "ERROR: $(echo "$response" | jq -r '.result.content[0].text')" >&2
    return 1
  fi
  echo "$response" | jq -r '.result.content[0].text'
}

ensure_db() {
  mkdir -p "$DB_DIR"
  sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS monitors (
    name TEXT PRIMARY KEY,
    query TEXT NOT NULL,
    webhook TEXT,
    interval_min INTEGER DEFAULT 15,
    last_checked TEXT,
    enabled INTEGER DEFAULT 1,
    created_at TEXT DEFAULT (datetime('now'))
);
CREATE TABLE IF NOT EXISTS alerts (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    monitor_name TEXT NOT NULL,
    match_count INTEGER,
    matches TEXT,
    fired_at TEXT DEFAULT (datetime('now')),
    FOREIGN KEY (monitor_name) REFERENCES monitors(name)
);
SQL

  # Gracefully add enabled column if migrating from older schema
  local has_enabled
  has_enabled=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM pragma_table_info('monitors') WHERE name='enabled';")
  if [[ "$has_enabled" -eq 0 ]]; then
    sqlite3 "$DB_PATH" "ALTER TABLE monitors ADD COLUMN enabled INTEGER DEFAULT 1;"
  fi
}

parse_matches() {
  local raw="$1"
  echo "$raw" | jq -c '[
    .data.search.results.results[:50] | .[] |
    if .commit then
      {
        repo:    .commit.repository.name,
        file:    null,
        line:    null,
        preview: (.commit.message.subject // .commit.abbreviatedOID)
      }
    elif .file then
      {
        repo:    .repository.name,
        file:    .file.path,
        line:    (.lineMatches[0].lineNumber // null),
        preview: (.lineMatches[0].preview // "")
      }
    else
      {
        repo:    (.repository.name // "unknown"),
        file:    null,
        line:    null,
        preview: ""
      }
    end
  ]'
}

fire_webhook() {
  local webhook="$1" payload="$2"
  curl -sf -X POST \
    -H "Content-Type: application/json" \
    -d "$payload" \
    "$webhook" >/dev/null 2>&1 || {
    echo "WARNING: webhook delivery failed for $webhook" >&2
  }
}

sql_escape() {
  echo "$1" | sed "s/'/''/g"
}

# ---- commands -------------------------------------------------------------

cmd_create() {
  local name="" query="" webhook="" interval="15"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)    name="$2";     shift 2 ;;
      --query)   query="$2";    shift 2 ;;
      --webhook) webhook="$2";  shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      *) echo "ERROR: unknown argument: $1" >&2; exit 1 ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "ERROR: --name is required" >&2; exit 1
  fi
  if [[ -z "$query" ]]; then
    echo "ERROR: --query is required" >&2; exit 1
  fi

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE name = '$(sql_escape "$name")';")
  if [[ "$existing" -gt 0 ]]; then
    echo "ERROR: monitor '$name' already exists" >&2; exit 1
  fi

  sqlite3 "$DB_PATH" "INSERT INTO monitors (name, query, webhook, interval_min, enabled) VALUES ('$(sql_escape "$name")', '$(sql_escape "$query")', '$(sql_escape "$webhook")', $interval, 1);"

  echo "Created monitor '$name'"
  echo "  Query:    $query"
  echo "  Webhook:  ${webhook:-<none>}"
  echo "  Interval: ${interval}m"
  echo "  Enabled:  true"
}

cmd_update() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "ERROR: monitor name is required" >&2; exit 1
  fi
  shift

  local query="" webhook="" interval=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --query)    query="$2";    shift 2 ;;
      --webhook)  webhook="$2";  shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      *) echo "ERROR: unknown argument: $1" >&2; exit 1 ;;
    esac
  done

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE name = '$(sql_escape "$name")';")
  if [[ "$existing" -eq 0 ]]; then
    echo "ERROR: monitor '$name' not found" >&2; exit 1
  fi

  local updates=()
  if [[ -n "$query" ]]; then
    updates+=("query = '$(sql_escape "$query")'")
  fi
  if [[ -n "$webhook" ]]; then
    updates+=("webhook = '$(sql_escape "$webhook")'")
  fi
  if [[ -n "$interval" ]]; then
    updates+=("interval_min = $interval")
  fi

  if [[ ${#updates[@]} -eq 0 ]]; then
    echo "ERROR: at least one of --query, --webhook, or --interval is required" >&2; exit 1
  fi

  local set_clause
  set_clause=$(IFS=', '; echo "${updates[*]}")

  sqlite3 "$DB_PATH" "UPDATE monitors SET $set_clause WHERE name = '$(sql_escape "$name")';"

  echo "Updated monitor '$name'"
  [[ -n "$query" ]]    && echo "  Query:    $query"
  [[ -n "$webhook" ]]  && echo "  Webhook:  $webhook"
  [[ -n "$interval" ]] && echo "  Interval: ${interval}m"
}

cmd_toggle() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "ERROR: monitor name is required" >&2; exit 1
  fi
  shift

  local enabled=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --enabled) enabled="$2"; shift 2 ;;
      *) echo "ERROR: unknown argument: $1" >&2; exit 1 ;;
    esac
  done

  if [[ -z "$enabled" ]]; then
    echo "ERROR: --enabled is required (true or false)" >&2; exit 1
  fi

  local enabled_int
  case "$enabled" in
    true)  enabled_int=1 ;;
    false) enabled_int=0 ;;
    *) echo "ERROR: --enabled must be 'true' or 'false'" >&2; exit 1 ;;
  esac

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE name = '$(sql_escape "$name")';")
  if [[ "$existing" -eq 0 ]]; then
    echo "ERROR: monitor '$name' not found" >&2; exit 1
  fi

  sqlite3 "$DB_PATH" "UPDATE monitors SET enabled = $enabled_int WHERE name = '$(sql_escape "$name")';"

  echo "Monitor '$name' is now $([ "$enabled_int" -eq 1 ] && echo 'enabled' || echo 'disabled')."
}

cmd_trigger_check() {
  local name="" since=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)  name="$2";  shift 2 ;;
      --since) since="$2"; shift 2 ;;
      *) echo "ERROR: unknown argument: $1" >&2; exit 1 ;;
    esac
  done

  ensure_db

  if [[ -n "$name" ]]; then
    trigger_check_single "$name" "$since"
  else
    local monitors
    monitors=$(sqlite3 "$DB_PATH" "SELECT name FROM monitors WHERE enabled = 1;")
    if [[ -z "$monitors" ]]; then
      echo "No enabled monitors configured."
      return 0
    fi
    while IFS= read -r mon; do
      trigger_check_single "$mon" "$since"
    done <<< "$monitors"
  fi
}

trigger_check_single() {
  local name="$1" since_override="$2"

  local row
  row=$(sqlite3 -separator '|' "$DB_PATH" \
    "SELECT query, webhook, last_checked, enabled FROM monitors WHERE name = '$(sql_escape "$name")';")

  if [[ -z "$row" ]]; then
    echo "ERROR: monitor '$name' not found" >&2
    return 1
  fi

  local query webhook last_checked enabled
  IFS='|' read -r query webhook last_checked enabled <<< "$row"

  if [[ "$enabled" -eq 0 ]]; then
    echo "Skipping disabled monitor '$name'."
    return 0
  fi

  local since
  if [[ -n "$since_override" ]]; then
    since="$since_override"
  elif [[ -n "$last_checked" ]]; then
    since="$last_checked"
  else
    since=$(date -u -v-1d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '1 day ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)
  fi

  local full_query="$query after:\"$since\""
  echo "Checking monitor '$name' (since $since)..."

  local raw_response
  local ts_args
  ts_args=$(jq -n --arg q "$full_query" '{query: $q, format: "raw", count: "50"}')
  raw_response=$(ts_call "sourcegraph__keyword_search" "$ts_args") || {
    echo "ERROR: Sourcegraph search failed for monitor '$name'" >&2
    return 1
  }

  local match_count
  match_count=$(echo "$raw_response" | jq -r '.data.search.results.matchCount // 0')

  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  sqlite3 "$DB_PATH" "UPDATE monitors SET last_checked = '$now' WHERE name = '$(sql_escape "$name")';"

  if [[ "$match_count" -gt 0 ]]; then
    local matches
    matches=$(parse_matches "$raw_response")

    sqlite3 "$DB_PATH" "INSERT INTO alerts (monitor_name, match_count, matches) VALUES ('$(sql_escape "$name")', $match_count, '$(echo "$matches" | sed "s/'/''/g")');"

    echo "  Found $match_count new match(es)"

    if [[ -n "$webhook" ]]; then
      local payload
      payload=$(jq -n \
        --arg monitor "$name" \
        --arg query "$query" \
        --argjson count "$match_count" \
        --argjson matches "$matches" \
        --arg checked_at "$now" \
        '{
          monitor: $monitor,
          query: $query,
          match_count: $count,
          matches: $matches,
          checked_at: $checked_at
        }')
      fire_webhook "$webhook" "$payload"
      echo "  Webhook fired to $webhook"
    fi

    echo "$matches" | jq -r '.[:5][] | "    - \(.repo) \(.file // "") \(if .line then "L\(.line)" else "" end): \(.preview)"'
    if [[ "$match_count" -gt 5 ]]; then
      echo "    ... and $((match_count - 5)) more"
    fi
  else
    echo "  No new matches."
  fi
}

cmd_trigger_check_all() {
  ensure_db

  local monitors
  monitors=$(sqlite3 "$DB_PATH" "SELECT name FROM monitors WHERE enabled = 1;")
  if [[ -z "$monitors" ]]; then
    echo "No enabled monitors configured."
    return 0
  fi

  local count=0
  while IFS= read -r mon; do
    trigger_check_single "$mon" ""
    count=$((count + 1))
  done <<< "$monitors"

  echo ""
  echo "Checked $count monitor(s)."
}

cmd_list() {
  ensure_db

  local rows
  rows=$(sqlite3 -separator '|' "$DB_PATH" \
    "SELECT m.name, m.query, m.last_checked, m.interval_min, m.webhook, m.enabled,
            COALESCE((SELECT match_count FROM alerts WHERE monitor_name = m.name ORDER BY fired_at DESC LIMIT 1), 0)
     FROM monitors m ORDER BY m.name;")

  if [[ -z "$rows" ]]; then
    echo "No monitors configured."
    return 0
  fi

  printf "%-20s %-35s %-22s %6s %7s %3s %s\n" "NAME" "QUERY" "LAST CHECKED" "ALERTS" "INTV" "ON" "WEBHOOK"
  printf "%-20s %-35s %-22s %6s %7s %3s %s\n" "----" "-----" "------------" "------" "----" "--" "-------"

  while IFS='|' read -r name query last_checked interval webhook enabled last_alert_count; do
    local wh_flag="n"
    [[ -n "$webhook" ]] && wh_flag="y"
    local on_flag="y"
    [[ "$enabled" -eq 0 ]] && on_flag="n"
    local display_query="$query"
    if [[ ${#display_query} -gt 35 ]]; then
      display_query="${display_query:0:32}..."
    fi
    printf "%-20s %-35s %-22s %6s %5sm %3s %s\n" \
      "$name" "$display_query" "${last_checked:-never}" "$last_alert_count" "$interval" "$on_flag" "$wh_flag"
  done <<< "$rows"
}

cmd_delete() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    echo "ERROR: monitor name is required" >&2; exit 1
  fi

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE name = '$(sql_escape "$name")';")
  if [[ "$existing" -eq 0 ]]; then
    echo "ERROR: monitor '$name' not found" >&2; exit 1
  fi

  sqlite3 "$DB_PATH" "DELETE FROM alerts WHERE monitor_name = '$(sql_escape "$name")';"
  sqlite3 "$DB_PATH" "DELETE FROM monitors WHERE name = '$(sql_escape "$name")';"

  echo "Deleted monitor '$name' and its event history."
}

cmd_events() {
  local name="${1:-}" limit="20"

  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) limit="$2"; shift 2 ;;
      *) echo "ERROR: unknown argument: $1" >&2; exit 1 ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "ERROR: monitor name is required" >&2; exit 1
  fi

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE name = '$(sql_escape "$name")';")
  if [[ "$existing" -eq 0 ]]; then
    echo "ERROR: monitor '$name' not found" >&2; exit 1
  fi

  local rows
  rows=$(sqlite3 -separator '|' "$DB_PATH" \
    "SELECT fired_at, match_count, matches FROM alerts
     WHERE monitor_name = '$(sql_escape "$name")'
     ORDER BY fired_at DESC LIMIT $limit;")

  if [[ -z "$rows" ]]; then
    echo "No trigger events for monitor '$name'."
    return 0
  fi

  echo "Recent trigger events for '$name':"
  echo ""

  while IFS='|' read -r fired_at match_count matches; do
    echo "  [$fired_at] $match_count match(es)"
    if [[ -n "$matches" && "$matches" != "null" ]]; then
      echo "$matches" | jq -r '.[:3][] | "    - \(.repo) \(.file // "") \(if .line then "L\(.line)" else "" end): \(.preview)"' 2>/dev/null || true
    fi
  done <<< "$rows"
}

cmd_test_action() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    echo "ERROR: monitor name is required" >&2; exit 1
  fi

  ensure_db

  local row
  row=$(sqlite3 -separator '|' "$DB_PATH" \
    "SELECT webhook FROM monitors WHERE name = '$(sql_escape "$name")';")

  if [[ -z "$row" ]]; then
    echo "ERROR: monitor '$name' not found" >&2; exit 1
  fi

  local webhook="$row"

  if [[ -z "$webhook" ]]; then
    echo "ERROR: monitor '$name' has no webhook configured" >&2; exit 1
  fi

  local payload
  payload=$(jq -n \
    --arg monitor "$name" \
    --arg checked_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      monitor: $monitor,
      query: "(test action)",
      match_count: 0,
      matches: [],
      checked_at: $checked_at,
      test: true
    }')

  echo "Sending test webhook to $webhook ..."
  fire_webhook "$webhook" "$payload"
  echo "Test webhook sent for monitor '$name'."
}

cmd_reset() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    echo "ERROR: monitor name is required" >&2; exit 1
  fi

  ensure_db

  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE name = '$(sql_escape "$name")';")
  if [[ "$existing" -eq 0 ]]; then
    echo "ERROR: monitor '$name' not found" >&2; exit 1
  fi

  sqlite3 "$DB_PATH" "UPDATE monitors SET last_checked = NULL WHERE name = '$(sql_escape "$name")';"

  echo "Reset trigger timestamps for monitor '$name'. Next check will re-evaluate from scratch."
}

cmd_health() {
  local errors=0

  # Check Sourcegraph via toolshed
  echo "Checking Sourcegraph connectivity..."
  local sg_health
  sg_health=$(ts_call "sourcegraph__health" "{}" 2>&1) && {
    echo "  Sourcegraph: OK"
    echo "$sg_health" | head -3 | sed 's/^/    /'
  } || {
    echo "  Sourcegraph: FAIL"
    echo "$sg_health" | head -3 | sed 's/^/    /'
    errors=$((errors + 1))
  }

  # Check DB
  echo "Checking database..."
  ensure_db
  local monitor_count alert_count enabled_count disabled_count
  monitor_count=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors;")
  alert_count=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM alerts;")
  enabled_count=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE enabled = 1;")
  disabled_count=$(sqlite3 "$DB_PATH" "SELECT count(*) FROM monitors WHERE enabled = 0;")
  echo "  Database: OK ($DB_PATH)"
  echo "  Monitors: $monitor_count ($enabled_count enabled, $disabled_count disabled)"
  echo "  Events:   $alert_count"

  if [[ "$errors" -gt 0 ]]; then
    echo ""
    echo "Health check completed with $errors error(s)."
    exit 1
  else
    echo ""
    echo "All checks passed."
  fi
}

# ---- dispatch -------------------------------------------------------------

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  create)            cmd_create "$@" ;;
  update)            cmd_update "$@" ;;
  delete)            cmd_delete "$@" ;;
  toggle)            cmd_toggle "$@" ;;
  trigger_check)     cmd_trigger_check "$@" ;;
  trigger_check_all) cmd_trigger_check_all "$@" ;;
  list)              cmd_list "$@" ;;
  events)            cmd_events "$@" ;;
  test_action)       cmd_test_action "$@" ;;
  reset)             cmd_reset "$@" ;;
  health)            cmd_health "$@" ;;
  *)
    echo "Usage: code-monitor <command> [args]"
    echo ""
    echo "Commands:"
    echo "  create            Create a new code monitor"
    echo "  update            Update a monitor's query, webhook, or interval"
    echo "  delete            Delete a monitor"
    echo "  toggle            Enable or disable a monitor"
    echo "  trigger_check     Evaluate trigger for a specific monitor (or all)"
    echo "  trigger_check_all Evaluate triggers for all enabled monitors"
    echo "  list              List all monitors with their status"
    echo "  events            Show recent trigger events for a monitor"
    echo "  test_action       Send a test webhook for a monitor"
    echo "  reset             Reset trigger timestamps (re-evaluate from scratch)"
    echo "  health            Check Sourcegraph connectivity and DB state"
    exit 1
    ;;
esac
