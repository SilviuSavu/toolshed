#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# sourcegraph — unified Sourcegraph tool (all 15 modules)
#
# Core commands are handled inline. Prefixed commands delegate to module
# scripts in ./modules/, stripping the prefix before dispatch.
###############################################################################

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODULES="$SCRIPT_DIR/modules"

COMMAND="${1:-}"
shift || true

# ---------------------------------------------------------------------------
# Route: prefix → module script, stripping prefix from command name
# ---------------------------------------------------------------------------

case "$COMMAND" in
    # --- Deep Search (LLM-driven multi-step research) ---
    deepsearch)
        exec "$MODULES/deepsearch" "$@"
        ;;
    deepsearch_read|deepsearch_list)
        exec "$MODULES/deepsearch-read" "${COMMAND#deepsearch_}" "$@"
        ;;

    # --- Code Intelligence (routes to narsil/lsp via toolshed) ---
    go_to_definition|find_references|nls_search)
        exec "$MODULES/code-intel" "$COMMAND" "$@"
        ;;

    # --- Core (inline) ---
    keyword_search|read_file|list_repos|list_files|symbols|\
    commit_search|diff_search|compare_revisions|get_contributor_repos|health)
        exec "$MODULES/core" "$COMMAND" "$@"
        ;;

    # --- Stream ---
    stream_*)
        exec "$MODULES/sg-stream" "${COMMAND#stream_}" "$@"
        ;;

    # --- Prompts ---
    prompts_*)
        exec "$MODULES/sg-prompts" "${COMMAND#prompts_}" "$@"
        ;;

    # --- Notebooks ---
    notebooks_*)
        exec "$MODULES/sg-notebooks" "${COMMAND#notebooks_}" "$@"
        ;;

    # --- Auth (admin) ---
    auth_*)
        exec "$MODULES/sg-auth" "${COMMAND#auth_}" "$@"
        ;;

    # --- RBAC (admin) ---
    rbac_*)
        exec "$MODULES/sg-rbac" "${COMMAND#rbac_}" "$@"
        ;;

    # --- External Services (admin) ---
    ext_svc_*)
        exec "$MODULES/sg-external-svc" "${COMMAND#ext_svc_}" "$@"
        ;;

    # --- Webhooks (admin) ---
    webhooks_*)
        exec "$MODULES/sg-webhooks" "${COMMAND#webhooks_}" "$@"
        ;;

    # --- Audit (admin) ---
    audit_*)
        exec "$MODULES/sg-audit" "${COMMAND#audit_}" "$@"
        ;;

    # --- Code Owners ---
    owners_list_repos)
        exec "$MODULES/code-owners" "list-repos" "$@"
        ;;
    owners_list_owners)
        exec "$MODULES/code-owners" "list-owners" "$@"
        ;;
    owners_*)
        exec "$MODULES/code-owners" "${COMMAND#owners_}" "$@"
        ;;

    # --- Code Insights ---
    insights_*)
        exec "$MODULES/code-insights" "${COMMAND#insights_}" "$@"
        ;;

    # --- Code Monitor ---
    monitor_*)
        exec "$MODULES/code-monitor" "${COMMAND#monitor_}" "$@"
        ;;

    # --- Batch Changes ---
    batch_*)
        exec "$MODULES/batch-changes" "${COMMAND#batch_}" "$@"
        ;;

    *)
        echo "ERROR: unknown command: $COMMAND" >&2
        echo "Run 'sourcegraph' with no args for available commands." >&2
        exit 1
        ;;
esac
